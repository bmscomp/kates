#!/bin/bash
# Single source of truth for all container images used by klster.
# Sourced by pull-images.sh and load-images-to-kind.sh.

# Strimzi Kafka
STRIMZI_IMAGES=(
    "quay.io/strimzi/operator:0.51.0"
    "quay.io/strimzi/kafka:0.51.0-kafka-4.2.0"
)

# CRD upgrade hook (used by Helm pre-upgrade Job)
CRD_UPGRADE_IMAGES=(
    "registry.k8s.io/kubectl:v1.33.0"
)

# Prometheus + Grafana monitoring stack
MONITORING_IMAGES=(
    "quay.io/prometheus/prometheus:v3.9.1"
    "quay.io/prometheus/alertmanager:v0.28.1"
    "quay.io/prometheus-operator/prometheus-operator:v0.79.2"
    "quay.io/prometheus-operator/prometheus-config-reloader:v0.79.2"
    "quay.io/prometheus-operator/admission-webhook:v0.79.2"
    "quay.io/prometheus/node-exporter:v1.8.2"
    "registry.k8s.io/kube-state-metrics/kube-state-metrics:v2.14.0"
    "registry.k8s.io/ingress-nginx/kube-webhook-certgen:v1.6.5"
    "docker.io/grafana/grafana:12.3.1"
    "quay.io/kiwigrid/k8s-sidecar:2.2.3"
)

# Kafka UI
KAFKA_UI_IMAGES=(
    "provectuslabs/kafka-ui:v0.7.2"
)

# Apicurio Schema Registry
APICURIO_IMAGES=(
    "apicurio/apicurio-registry-kafkasql:2.2.5.Final"
)

# LitmusChaos core (docker.io)
LITMUS_CORE_IMAGES=(
    "litmuschaos/chaos-operator:3.27.0"
    "litmuschaos/chaos-runner:3.27.0"
    "litmuschaos/chaos-exporter:3.27.0"
    "litmuschaos/go-runner:3.27.0"
    "litmuschaos/litmusportal-subscriber:3.27.0"
    "litmuschaos/litmusportal-event-tracker:3.27.0"
)

# LitmusChaos portal (pulled from scarf.sh, tagged to canonical names for Kind)
# Format: "scarf_source|canonical_name"
LITMUS_SCARF_IMAGES=(
    "litmuschaos.docker.scarf.sh/litmuschaos/litmusportal-auth-server:3.27.0|litmuschaos/litmusportal-auth-server:3.27.0"
    "litmuschaos.docker.scarf.sh/litmuschaos/litmusportal-frontend:3.27.0|litmuschaos/litmusportal-frontend:3.27.0"
    "litmuschaos.docker.scarf.sh/litmuschaos/litmusportal-server:3.27.0|litmuschaos/litmusportal-server:3.27.0"
    "litmuschaos.docker.scarf.sh/litmuschaos/workflow-controller:v3.3.1|litmuschaos/workflow-controller:v3.3.1"
    "litmuschaos.docker.scarf.sh/litmuschaos/litmusportal-subscriber:3.27.0|litmuschaos/litmusportal-subscriber-scarf:3.27.0"
    "litmuschaos.docker.scarf.sh/litmuschaos/litmusportal-event-tracker:3.27.0|litmuschaos/litmusportal-event-tracker-scarf:3.27.0"
    "litmuschaos.docker.scarf.sh/litmuschaos/mongo:6|litmuschaos/mongo:6"
)

# MongoDB dependencies
MONGO_IMAGES=(
    "docker.io/library/mongo:6.0"
    "docker.io/bitnamilegacy/os-shell:12-debian-12-r51"
)

# amd64-only images — bitnamilegacy/mongodb is amd64-only (no arm64 variant).
# For Kind on Apple Silicon, use the external MongoDB StatefulSet (mongo:6.0) instead.
# This array is intentionally empty for arm64 environments.
AMD64_ONLY_IMAGES=()

# Velero backup + MinIO
VELERO_IMAGES=(
    "docker.io/velero/velero:v1.17.1"
    "docker.io/velero/velero-plugin-for-aws:v1.10.0"
    "docker.io/minio/minio:RELEASE.2024-09-22T00-33-43Z"
    "docker.io/minio/mc:RELEASE.2024-09-16T17-43-14Z"
    "docker.io/bitnamilegacy/kubectl:1.17.1"
)

# Kates application dependencies
KATES_IMAGES=(
    "docker.io/library/postgres:17-alpine"
)

# Jaeger distributed tracing (v2 — matches config/monitoring/jaeger-values.yaml)
JAEGER_IMAGES=(
    "jaegertracing/jaeger:2.15.0"
)

# Headlamp Kubernetes dashboard
HEADLAMP_IMAGES=(
    "ghcr.io/headlamp-k8s/headlamp:v0.40.1"
)

# All standard images (non-scarf) combined for iteration
ALL_STANDARD_IMAGES=(
    "${STRIMZI_IMAGES[@]}"
    "${CRD_UPGRADE_IMAGES[@]}"
    "${MONITORING_IMAGES[@]}"
    "${KAFKA_UI_IMAGES[@]}"
    "${APICURIO_IMAGES[@]}"
    "${LITMUS_CORE_IMAGES[@]}"
    "${MONGO_IMAGES[@]}"
    "${VELERO_IMAGES[@]}"
    "${KATES_IMAGES[@]}"
    "${JAEGER_IMAGES[@]}"
    "${HEADLAMP_IMAGES[@]}"
)
