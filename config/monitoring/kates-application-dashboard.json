{
    "annotations": {
        "list": [
            {
                "builtIn": 1,
                "datasource": "-- Grafana --",
                "enable": true,
                "hide": true,
                "iconColor": "rgba(0, 211, 255, 1)",
                "name": "Annotations & Alerts",
                "type": "dashboard"
            }
        ]
    },
    "editable": true,
    "graphTooltip": 1,
    "panels": [
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "title": "Pod Status",
            "type": "row"
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 5,
                "w": 6,
                "x": 0,
                "y": 1
            },
            "id": 2,
            "options": {
                "colorMode": "background",
                "graphMode": "none"
            },
            "title": "Kates Pods Ready",
            "type": "stat",
            "targets": [
                {
                    "expr": "sum(kube_pod_status_ready{namespace=\"kates\", pod=~\"kates-.*\", condition=\"true\"})",
                    "legendFormat": "Ready",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 5,
                "w": 6,
                "x": 6,
                "y": 1
            },
            "id": 3,
            "options": {
                "colorMode": "background",
                "graphMode": "area"
            },
            "title": "Restarts (5m)",
            "type": "stat",
            "targets": [
                {
                    "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"kates\", container=\"kates\"}[5m]))",
                    "legendFormat": "Restarts",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                }
            },
            "gridPos": {
                "h": 5,
                "w": 6,
                "x": 12,
                "y": 1
            },
            "id": 4,
            "options": {
                "colorMode": "background",
                "graphMode": "none"
            },
            "title": "Uptime",
            "type": "stat",
            "targets": [
                {
                    "expr": "time() - min(kube_pod_start_time{namespace=\"kates\", pod=~\"kates-.*\"})",
                    "legendFormat": "Uptime",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 5,
                "w": 6,
                "x": 18,
                "y": 1
            },
            "id": 5,
            "options": {
                "colorMode": "background",
                "graphMode": "none"
            },
            "title": "Postgres Ready",
            "type": "stat",
            "targets": [
                {
                    "expr": "sum(kube_pod_status_ready{namespace=\"kates\", pod=~\"postgres-.*\", condition=\"true\"})",
                    "legendFormat": "Ready",
                    "refId": "A"
                }
            ]
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 6
            },
            "id": 10,
            "title": "HTTP Server",
            "type": "row"
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 7
            },
            "id": 11,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom"
                }
            },
            "title": "Request Rate (by method)",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "sum by (method) (rate(http_server_requests_seconds_count{job=\"kates\"}[1m]))",
                    "legendFormat": "{{method}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 7
            },
            "id": 12,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom"
                }
            },
            "title": "Error Rate (4xx / 5xx)",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"kates\", status=~\"4..|5..\"}[1m]))",
                    "legendFormat": "{{status}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 7
            },
            "id": 13,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom"
                }
            },
            "title": "Request Latency (p50 / p95 / p99)",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"kates\"}[1m])))",
                    "legendFormat": "p50",
                    "refId": "A"
                },
                {
                    "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"kates\"}[1m])))",
                    "legendFormat": "p95",
                    "refId": "B"
                },
                {
                    "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"kates\"}[1m])))",
                    "legendFormat": "p99",
                    "refId": "C"
                }
            ]
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 15
            },
            "id": 20,
            "title": "JVM",
            "type": "row"
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 16
            },
            "id": 21,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                }
            },
            "title": "Heap Memory (Used vs Committed)",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "jvm_memory_used_bytes{job=\"kates\", area=\"heap\"}",
                    "legendFormat": "Used",
                    "refId": "A"
                },
                {
                    "expr": "jvm_memory_committed_bytes{job=\"kates\", area=\"heap\"}",
                    "legendFormat": "Committed",
                    "refId": "B"
                },
                {
                    "expr": "jvm_memory_max_bytes{job=\"kates\", area=\"heap\"}",
                    "legendFormat": "Max",
                    "refId": "C"
                }
            ]
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 16
            },
            "id": 22,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                }
            },
            "title": "GC Pause Duration",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "rate(jvm_gc_pause_seconds_sum{job=\"kates\"}[1m])",
                    "legendFormat": "{{cause}} {{action}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 16
            },
            "id": 23,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                }
            },
            "title": "Thread Count",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "jvm_threads_live_threads{job=\"kates\"}",
                    "legendFormat": "Live",
                    "refId": "A"
                },
                {
                    "expr": "jvm_threads_daemon_threads{job=\"kates\"}",
                    "legendFormat": "Daemon",
                    "refId": "B"
                },
                {
                    "expr": "jvm_threads_peak_threads{job=\"kates\"}",
                    "legendFormat": "Peak",
                    "refId": "C"
                }
            ]
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 24
            },
            "id": 30,
            "title": "Database (Agroal Pool)",
            "type": "row"
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 25
            },
            "id": 31,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                }
            },
            "title": "DB Connections",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "agroal_active_count{job=\"kates\"}",
                    "legendFormat": "Active",
                    "refId": "A"
                },
                {
                    "expr": "agroal_available_count{job=\"kates\"}",
                    "legendFormat": "Available",
                    "refId": "B"
                },
                {
                    "expr": "agroal_max_used_count{job=\"kates\"}",
                    "legendFormat": "Max Used",
                    "refId": "C"
                }
            ]
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 25
            },
            "id": 32,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                }
            },
            "title": "DB Acquire Time",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "rate(agroal_acquire_count{job=\"kates\"}[1m])",
                    "legendFormat": "Acquire Rate",
                    "refId": "A"
                },
                {
                    "expr": "agroal_blocking_time_total_seconds{job=\"kates\"} / agroal_blocking_time_count{job=\"kates\"}",
                    "legendFormat": "Avg Blocking Time",
                    "refId": "B"
                }
            ]
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 33
            },
            "id": 40,
            "title": "Resource Usage",
            "type": "row"
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "percent"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 34
            },
            "id": 41,
            "options": {
                "legend": {
                    "displayMode": "list"
                }
            },
            "title": "CPU Usage",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "rate(container_cpu_usage_seconds_total{namespace=\"kates\", container=\"kates\"}[5m]) * 100",
                    "legendFormat": "{{pod}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": "prometheus",
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 34
            },
            "id": 42,
            "options": {
                "legend": {
                    "displayMode": "list"
                }
            },
            "title": "Memory Usage (RSS)",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "container_memory_rss{namespace=\"kates\", container=\"kates\"}",
                    "legendFormat": "RSS {{pod}}",
                    "refId": "A"
                },
                {
                    "expr": "container_memory_working_set_bytes{namespace=\"kates\", container=\"kates\"}",
                    "legendFormat": "Working Set {{pod}}",
                    "refId": "B"
                }
            ]
        }
    ],
    "refresh": "10s",
    "schemaVersion": 38,
    "tags": [
        "kates",
        "application",
        "health"
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-1h",
