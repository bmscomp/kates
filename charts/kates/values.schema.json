{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "replicaCount": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of Kates replicas"
        },
        "image": {
            "type": "object",
            "properties": {
                "repository": {
                    "type": "string",
                    "minLength": 1
                },
                "tag": {
                    "type": "string",
                    "minLength": 1
                },
                "pullPolicy": {
                    "type": "string",
                    "enum": [
                        "Always",
                        "Never",
                        "IfNotPresent"
                    ]
                }
            },
            "required": [
                "repository",
                "tag"
            ]
        },
        "serviceAccount": {
            "type": "object",
            "properties": {
                "create": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                },
                "automount": {
                    "type": "boolean"
                }
            }
        },
        "rbac": {
            "type": "object",
            "properties": {
                "create": {
                    "type": "boolean"
                },
                "extraRules": {
                    "type": "array"
                }
            }
        },
        "service": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "ClusterIP",
                        "NodePort",
                        "LoadBalancer"
                    ]
                },
                "port": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535
                },
                "appProtocol": {
                    "type": "string"
                }
            }
        },
        "ingress": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "className": {
                    "type": "string"
                }
            }
        },
        "resources": {
            "type": "object",
            "properties": {
                "requests": {
                    "type": "object"
                },
                "limits": {
                    "type": "object"
                }
            }
        },
        "terminationGracePeriodSeconds": {
            "type": "integer",
            "minimum": 0
        },
        "autoscaling": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "minReplicas": {
                    "type": "integer",
                    "minimum": 1
                },
                "maxReplicas": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        },
        "podDisruptionBudget": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                }
            }
        },
        "probes": {
            "type": "object",
            "properties": {
                "startup": {
                    "type": "object",
                    "properties": {
                        "path": {
                            "type": "string",
                            "pattern": "^/"
                        },
                        "failureThreshold": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "periodSeconds": {
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                },
                "readiness": {
                    "type": "object",
                    "properties": {
                        "path": {
                            "type": "string",
                            "pattern": "^/"
                        },
                        "initialDelaySeconds": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "periodSeconds": {
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                },
                "liveness": {
                    "type": "object",
                    "properties": {
                        "path": {
                            "type": "string",
                            "pattern": "^/"
                        },
                        "initialDelaySeconds": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "periodSeconds": {
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                }
            }
        },
        "lifecycle": {
            "type": "object",
            "properties": {
                "preStopSleepSeconds": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 300
                }
            }
        },
        "kafka": {
            "type": "object",
            "properties": {
                "bootstrapServers": {
                    "type": "string",
                    "minLength": 1
                },
                "clientRack": {
                    "type": "string"
                },
                "security": {
                    "type": "object",
                    "properties": {
                        "protocol": {
                            "type": "string",
                            "enum": [
                                "PLAINTEXT",
                                "SASL_PLAINTEXT",
                                "SSL",
                                "SASL_SSL"
                            ]
                        }
                    }
                },
                "sasl": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "mechanism": {
                            "type": "string",
                            "enum": [
                                "SCRAM-SHA-512",
                                "SCRAM-SHA-256",
                                "PLAIN",
                                "OAUTHBEARER"
                            ]
                        },
                        "username": {
                            "type": "string"
                        },
                        "secretName": {
                            "type": "string"
                        },
                        "secretKey": {
                            "type": "string"
                        },
                        "oauthbearer": {
                            "type": "object",
                            "properties": {
                                "tokenEndpointUrl": {
                                    "type": "string"
                                },
                                "clientId": {
                                    "type": "string"
                                },
                                "clientSecretName": {
                                    "type": "string"
                                },
                                "clientSecretKey": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "ssl": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "truststore": {
                            "type": "object",
                            "properties": {
                                "secretName": {
                                    "type": "string"
                                },
                                "key": {
                                    "type": "string"
                                },
                                "password": {
                                    "type": "string"
                                }
                            }
                        },
                        "keystore": {
                            "type": "object",
                            "properties": {
                                "secretName": {
                                    "type": "string"
                                },
                                "key": {
                                    "type": "string"
                                },
                                "password": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "required": [
                "bootstrapServers"
            ]
        },
        "engine": {
            "type": "object",
            "properties": {
                "defaultBackend": {
                    "type": "string",
                    "enum": [
                        "native",
                        "trogdor"
                    ]
                }
            }
        },
        "networkPolicy": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "kafka": {
                    "type": "object",
                    "properties": {
                        "namespace": {
                            "type": "string"
                        },
                        "port": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 65535
                        }
                    }
                },
                "prometheus": {
                    "type": "object",
                    "properties": {
                        "namespace": {
                            "type": "string"
                        },
                        "port": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 65535
                        }
                    }
                }
            }
        },
        "metrics": {
            "type": "object",
            "properties": {
                "serviceMonitor": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "interval": {
                            "type": "string",
                            "pattern": "^[0-9]+[smh]$"
                        }
                    }
                },
                "prometheusRule": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        }
                    }
                },
                "grafanaDashboard": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        }
                    }
                }
            }
        },
        "postgresql": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "auth": {
                    "type": "object",
                    "properties": {
                        "database": {
                            "type": "string",
                            "minLength": 1
                        },
                        "username": {
                            "type": "string",
                            "minLength": 1
                        }
                    }
                },
                "storage": {
                    "type": "object",
                    "properties": {
                        "size": {
                            "type": "string",
                            "pattern": "^[0-9]+[KMGT]i$"
                        }
                    }
                }
            }
        },
        "externalDatabase": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "host": {
                    "type": "string"
                },
                "port": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535
                },
                "database": {
                    "type": "string"
                }
            }
        },
        "defaults": {
            "type": "object",
            "properties": {
                "compressionType": {
                    "type": "string",
                    "enum": [
                        "none",
                        "gzip",
                        "snappy",
                        "lz4",
                        "zstd"
                    ]
                },
                "acks": {
                    "type": "string",
                    "enum": [
                        "0",
                        "1",
                        "all",
                        "-1"
                    ]
                }
            }
        },
        "backup": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "schedule": {
                    "type": "string"
                },
                "retention": {
                    "type": "integer",
                    "minimum": 1
                },
                "persistence": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "existingClaim": {
                            "type": "string"
                        },
                        "storageClass": {
                            "type": "string"
                        },
                        "size": {
                            "type": "string",
                            "pattern": "^[0-9]+[KMGT]i$"
                        }
                    }
                }
            }
        },
        "cleanup": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "retentionDays": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        }
    },
    "required": [
        "replicaCount",
        "image",
        "kafka"
    ]
}